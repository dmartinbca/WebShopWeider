@page "/politica-privacidad"
@inject LocalizationService L
@implements IDisposable

<PageTitle>@L.T("privacy_page_title")</PageTitle>

<div class="privacy-policy-container">
    <div class="container">
        <!-- Header -->
        <header class="privacy-header mb-5">
            <img src="/images/Weiderlogo.png" alt="Weider Nutrition Logo" class="privacy-logo mb-4" />
            <h1 class="privacy-title">@L.T("privacy_title")</h1>
            <p class="privacy-subtitle">@L.T("privacy_last_updated")</p>
        </header>

        <!-- Contenido principal -->
        <article class="privacy-content">
            <section class="privacy-section">
                <h2 class="section-title">@L.T("privacy_data_protection_title")</h2>
                <p class="section-text">@L.T("privacy_data_protection_text")</p>
                <p class="section-text">@L.T("privacy_data_purpose")</p>
            </section>

            <section class="privacy-section">
                <h2 class="section-title">@L.T("privacy_rights_title")</h2>
                <p class="section-text">@L.T("privacy_rights_intro")</p>
                <ul class="rights-list">
                    <li class="right-item">
                        <strong>@L.T("privacy_right_access"):</strong> @L.T("privacy_right_access_desc")
                    </li>
                    <li class="right-item">
                        <strong>@L.T("privacy_right_rectification"):</strong> @L.T("privacy_right_rectification_desc")
                    </li>
                    <li class="right-item">
                        <strong>@L.T("privacy_right_erasure"):</strong> @L.T("privacy_right_erasure_desc")
                    </li>
                    <li class="right-item">
                        <strong>@L.T("privacy_right_restriction"):</strong> @L.T("privacy_right_restriction_desc")
                    </li>
                    <li class="right-item">
                        <strong>@L.T("privacy_right_objection"):</strong> @L.T("privacy_right_objection_desc")
                    </li>
                </ul>
            </section>

            <section class="privacy-section">
                <h2 class="section-title">@L.T("privacy_contact_title")</h2>
                <p class="section-text">@L.T("privacy_contact_intro")</p>
                <div class="contact-info">
                    <div class="contact-block">
                        <p class="contact-value"><strong>WEIDER NUTRITION, SL</strong></p>
                    </div>
                    <div class="contact-block">
                        <p class="contact-value">Calle Electrónica, nº 39-41</p>
                        <p class="contact-value">28923, Alcorcón, Madrid</p>
                    </div>
                </div>
            </section>

            <section class="privacy-section">
                <h2 class="section-title">@L.T("privacy_confidentiality_title")</h2>
                <p class="section-text confidentiality-notice">@L.T("privacy_confidentiality_text")</p>
            </section>

            <section class="privacy-section border-top pt-4">
                <p class="footer-note">@L.T("privacy_confidentiality_note")</p>
            </section>
        </article>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}

<style>
    .privacy-policy-container {
        background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .privacy-header {
        text-align: center;
        padding-bottom: 2rem;
        border-bottom: 3px solid #e9ecef;
    }

    .privacy-logo {
        max-width: 120px;
        height: auto;
        display: block;
        margin: 0 auto;
    }

    .privacy-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #212529;
        margin: 1.5rem 0 0.5rem 0;
        letter-spacing: -0.5px;
    }

    .privacy-subtitle {
        font-size: 0.95rem;
        color: #6c757d;
        margin: 0;
        font-weight: 500;
    }

    .privacy-content {
        background: white;
        border-radius: 8px;
        padding: 2.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .privacy-section {
        margin-bottom: 2.5rem;
    }

    .privacy-section:last-child {
        margin-bottom: 0;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #f0f0f0;
    }

    .section-text {
        font-size: 1rem;
        line-height: 1.8;
        color: #495057;
        margin-bottom: 1rem;
    }

    .section-text strong {
        color: #212529;
        font-weight: 600;
    }

    .confidentiality-notice {
        background-color: #fff3cd;
        padding: 1rem;
        border-left: 4px solid #ffc107;
        border-radius: 4px;
        margin-bottom: 1rem;
    }

    .rights-list {
        list-style: none;
        padding: 0;
        margin: 1.5rem 0;
    }

    .right-item {
        padding: 0.75rem 0;
        padding-left: 1.5rem;
        position: relative;
        color: #495057;
        line-height: 1.8;
        margin-bottom: 0.75rem;
    }

    .right-item::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #28a745;
        font-weight: bold;
        font-size: 1.1rem;
    }

    .right-item strong {
        color: #212529;
    }

    .contact-info {
        background-color: #f8f9fa;
        border-radius: 6px;
        padding: 1.5rem;
        margin: 1.5rem 0;
        border: 1px solid #e9ecef;
    }

    .contact-block {
        margin-bottom: 1rem;
    }

    .contact-block:last-child {
        margin-bottom: 0;
    }

    .contact-label {
        font-weight: 700;
        color: #212529;
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
    }

    .contact-value {
        color: #495057;
        margin: 0.25rem 0;
        font-size: 1rem;
    }

    .footer-note {
        font-style: italic;
        color: #6c757d;
        background-color: #f0f0f0;
        padding: 1rem;
        border-radius: 4px;
        border-left: 4px solid #868e96;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .privacy-policy-container {
            padding: 1rem 0;
        }

        .privacy-header {
            padding-bottom: 1.5rem;
        }

        .privacy-title {
            font-size: 1.75rem;
        }

        .privacy-content {
            padding: 1.5rem 1rem;
            border-radius: 6px;
        }

        .section-title {
            font-size: 1.25rem;
            margin-bottom: 0.75rem;
        }

        .section-text {
            font-size: 0.95rem;
        }

        .contact-info {
            padding: 1rem;
        }

        .privacy-logo {
            max-width: 100px;
        }
    }

    @@media (max-width: 576px) {
        .privacy-title {
            font-size: 1.5rem;
        }

        .privacy-content {
            padding: 1rem;
        }

        .section-title {
            font-size: 1.1rem;
        }

        .section-text {
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .right-item {
            padding-left: 1.25rem;
            font-size: 0.9rem;
        }

        .contact-info {
            padding: 0.75rem;
        }
    }
</style>
